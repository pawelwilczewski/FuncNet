<!-- FuncNet.Analyzers MSBuild targets file -->
<Project>
    <!-- Define config file properties -->
    <PropertyGroup>
        <FuncNetConfigFullPath>$(MSBuildProjectDirectory)\$(FuncNetConfigFileName)</FuncNetConfigFullPath>
        <FuncNetDirectoryBuildPropsFile>$(MSBuildProjectDirectory)\Directory.FuncNet.props</FuncNetDirectoryBuildPropsFile>
        <FuncNetDirectoryBuildPath>$(MSBuildProjectDirectory)\Directory.Build.props</FuncNetDirectoryBuildPath>
    </PropertyGroup>

    <!-- Create a default empty configuration file if it doesn't exist -->
    <Target Name="EnsureFuncNetConfigExists" BeforeTargets="BeforeCompile">
        <!-- Default content and existence check -->
        <PropertyGroup>
            <DefaultFuncNetConfigContent>{"UnionRegistrations":[]}</DefaultFuncNetConfigContent>
            <ConfigFileExists Condition="Exists('$(FuncNetConfigFullPath)')">true</ConfigFileExists>
            <ConfigFileExists Condition="!Exists('$(FuncNetConfigFullPath)')">false</ConfigFileExists>
            
            <!-- FuncNet props file content -->
            <FuncNetPropsContent>
<![CDATA[<?xml version="1.0" encoding="utf-8"?>
<!-- This file is automatically generated by FuncNet.Analyzers -->
<!-- Do not modify this file manually -->
<Project>
    <ItemGroup>
        <AdditionalFiles Include="$(FuncNetConfigFileName)" />
    </ItemGroup>
</Project>
]]>
            </FuncNetPropsContent>
            
            <!-- New Directory.Build.props content if needed -->
            <DirectoryBuildContent>
<![CDATA[<?xml version="1.0" encoding="utf-8"?>
<!-- This file was generated by FuncNet.Analyzers -->
<Project>
    <Import Project="Directory.FuncNet.props" Condition="Exists('Directory.FuncNet.props')" />
</Project>
]]>
            </DirectoryBuildContent>
        </PropertyGroup>

        <!-- Create the config file if it doesn't exist -->
        <WriteLinesToFile
            File="$(FuncNetConfigFullPath)"
            Lines="$(DefaultFuncNetConfigContent)"
            Overwrite="false"
            Condition="'$(ConfigFileExists)' == 'false'" />

        <Message 
            Text="Created default FuncNet configuration file at $(FuncNetConfigFullPath)" 
            Importance="high" 
            Condition="'$(ConfigFileExists)' == 'false'" />

        <Message 
            Text="Using existing FuncNet configuration file at $(FuncNetConfigFullPath)" 
            Importance="normal" 
            Condition="'$(ConfigFileExists)' == 'true'" />
            
        <!-- Create the Directory.FuncNet.props file -->
        <WriteLinesToFile
            File="$(FuncNetDirectoryBuildPropsFile)"
            Lines="$(FuncNetPropsContent)"
            Overwrite="true" />
            
        <!-- Create Directory.Build.props if it doesn't exist -->
        <WriteLinesToFile
            File="$(FuncNetDirectoryBuildPath)"
            Lines="$(DirectoryBuildContent)"
            Overwrite="false"
            Condition="!Exists('$(FuncNetDirectoryBuildPath)')" />
            
        <!-- Add import to existing Directory.Build.props if it exists and doesn't have our import -->
        <ReadLinesFromFile
            File="$(FuncNetDirectoryBuildPath)"
            Condition="Exists('$(FuncNetDirectoryBuildPath)')">
            <Output TaskParameter="Lines" ItemName="ExistingDirectoryBuildContent" />
        </ReadLinesFromFile>
        
        <PropertyGroup>
            <ContainsImport>false</ContainsImport>
            <ContainsImport Condition="'@(ExistingDirectoryBuildContent)' != '' and '@(ExistingDirectoryBuildContent->AnyContains('Directory.FuncNet.props'))' == 'true'">true</ContainsImport>
            <NeedsUpdate Condition="'$(ContainsImport)' == 'false' and Exists('$(FuncNetDirectoryBuildPath)')">true</NeedsUpdate>
        </PropertyGroup>
        
        <!-- Update the Directory.Build.props with our import if needed -->
        <PropertyGroup Condition="'$(NeedsUpdate)' == 'true'">
            <ImportLine>    &lt;Import Project="Directory.FuncNet.props" Condition="Exists('Directory.FuncNet.props')" /&gt;</ImportLine>
            <UpdatedContent>@(ExistingDirectoryBuildContent)</UpdatedContent>
        </PropertyGroup>
        
        <ItemGroup Condition="'$(NeedsUpdate)' == 'true'">
            <UpdatedLines Include="@(ExistingDirectoryBuildContent)" />
            <UpdatedLines Include="$(ImportLine)" 
                         Condition="'@(ExistingDirectoryBuildContent)' != '' and '@(ExistingDirectoryBuildContent->Contains('&lt;/Project&gt;'))' == 'true' and '@(ExistingDirectoryBuildContent->IndexOf('&lt;/Project&gt;'))' == '@(ExistingDirectoryBuildContent->Count())'-1" />
        </ItemGroup>
        
        <WriteLinesToFile
            File="$(FuncNetDirectoryBuildPath)"
            Lines="@(UpdatedLines)"
            Overwrite="true"
            Condition="'$(NeedsUpdate)' == 'true'" />
            
        <!-- Add the config file as an AdditionalFile for this build -->
        <ItemGroup>
            <AdditionalFiles Include="$(FuncNetConfigFullPath)" />
        </ItemGroup>
        
        <!-- Log actions -->
        <Message 
            Text="Created Directory.Build.props with import for Directory.FuncNet.props" 
            Importance="high" 
            Condition="!Exists('$(FuncNetDirectoryBuildPath)')" />
            
        <Message 
            Text="Updated Directory.Build.props to import Directory.FuncNet.props" 
            Importance="high" 
            Condition="'$(NeedsUpdate)' == 'true'" />
    </Target>
</Project>
